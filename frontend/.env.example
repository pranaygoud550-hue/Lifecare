# ── Local development ─────────────────────────────────────────────────────────
# Vite proxies /api to the backend — use relative URL
VITE_API_URL=/api
VITE_SOCKET_URL=http://localhost:5001
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ── Production (Vite loads frontend/.env.production on `vite build`) ──
# Also set in vercel.json `env` — committed so every Vercel deploy hits Render over HTTPS.
# VITE_API_URL=https://lifecare-l42k.onrender.com/api
# VITE_SOCKET_URL=https://lifecare-l42k.onrender.com
# VITE_SITE_URL=https://lifecare-frontend-navy.vercel.app
# Railway example:
# VITE_API_URL=https://lifecare-backend.up.railway.app/api
# VITE_SOCKET_URL=https://lifecare-backend.up.railway.app
# VITE_SITE_URL=https://lifecare-frontend.up.railway.app
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
#
# Google Maps — NOT required on frontend. Hospitals + routes call Google from the
# backend (Render). Set GOOGLE_MAPS_API_KEY + GOOGLE_PLACES_API_KEY on Render only.
