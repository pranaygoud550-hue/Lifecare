# ── Local development ─────────────────────────────────────────────────────────
# Vite proxies /api to the backend — use relative URL
VITE_API_URL=/api
VITE_SOCKET_URL=http://localhost:5001
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

