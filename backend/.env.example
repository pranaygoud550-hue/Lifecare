PORT=5001
NODE_ENV=development
# Local Docker (npm run db:up) — use 127.0.0.1 not localhost on macOS
MONGODB_URI=mongodb://127.0.0.1:27017/lifecare-plus
# MongoDB Atlas example:
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/lifecare-plus?retryWrites=true&w=majority
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173
# Railway production — exact frontend origin, no trailing slash:
# FRONTEND_URL=https://lifecare-frontend.up.railway.app
# Optional extra origins (comma-separated):
# FRONTEND_URLS=https://www.lifecare.plus
# BACKEND_URL=https://lifecare-backend.up.railway.app
BACKEND_URL=
# Required on Railway backend service:
# NODE_ENV=production
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Optional in development — scans save to backend/uploads/mediscan/ when Cloudinary is unset
MEDISCAN_API_URL=http://localhost:8000
