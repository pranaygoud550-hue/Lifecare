PORT=5001
NODE_ENV=development
# Local Docker (npm run db:up) — use 127.0.0.1 not localhost on macOS
MONGODB_URI=mongodb://127.0.0.1:27017/lifecare-plus
# MongoDB Atlas example:
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/lifecare-plus?retryWrites=true&w=majority
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173
# Production — exact frontend origin, no trailing slash:
# Vercel + Render:
# FRONTEND_URL=https://lifecare.vercel.app
# BACKEND_URL=https://lifecare-api.onrender.com
# Railway:
# FRONTEND_URL=https://lifecare-frontend.up.railway.app
# BACKEND_URL=https://lifecare-backend.up.railway.app
# Optional extra origins (comma-separated):
# FRONTEND_URLS=https://www.lifecare.plus
BACKEND_URL=
# Required on Railway backend service:
# NODE_ENV=production
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# MediScan ML — remote API tried first; integrated local screening used when unavailable
MEDISCAN_API_URL=https://mediscan-api.onrender.com
# MEDISCAN_FORCE_LOCAL=true
# MEDISCAN_USE_LOCAL_FALLBACK=true
# Google Maps Platform (console.cloud.google.com → project "LifeCare+")
# Enable billing ($200/mo free credit — student usage stays free)
# APIs & Services → Library → enable: Places API, Directions API
#   (optional: Geocoding API, Distance Matrix API; Maps JavaScript API not needed — maps use Leaflet)
# Credentials → Create API key → restrict APIs to Places + Directions only
# IMPORTANT: Application restriction = "None" (or IP) — NOT "HTTP referrers"
#   Referrer restriction breaks server-side calls from Render/localhost backend
# Paste the SAME key in both vars below:
GOOGLE_PLACES_API_KEY=
GOOGLE_MAPS_API_KEY=
# Hospital/navigation API responses cached in-memory for 10 min (no Redis required for student deploy)
# Enable one-click demo login on production (for recruiters / judges only — disable for real users)
ALLOW_DEMO_LOGIN=true
# Set false in test/CI to avoid async emergency demo timers (Jest sets this automatically)
# DISABLE_EMERGENCY_DEMO=true
# Production: use MongoDB Atlas — see docs/DEPLOY_ATLAS.md (avoid in-memory fallback on Render)
# RapidCare external webhook (POST /api/rapidcare/sync) — header: x-webhook-secret
RAPIDCARE_WEBHOOK_SECRET=rapidcare_lifecare_secret_2024
